{
  "name": "@testmutant/cli",
  "version": "1.0.0-alpha.6",
  "description": "TestMutant CLI.",
  "private": false,
  "main": "dist/index.js",
  "bin": {
    "testmutant": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup && node scripts/fix-dist-mode.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:package": "node scripts/verify-hosted-runner-package.mjs",
    "check": "npm run typecheck && npm test && npm run build && npm run test:package",
    "check:dist": "git diff --exit-code -- dist",
    "ci": "node dist/index.js ci",
    "release:alpha": "npm version prerelease --preid alpha --no-git-tag-version && npm run check",
    "release:stable": "npm version 1.0.0 --no-git-tag-version && npm run check",
    "prepublishOnly": "npm run check"
  },
  "simple-git-hooks": {
    "pre-push": "npm run typecheck && npm test && npm run build && npm run test:package && git diff --exit-code -- dist"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TestMutant/cli.git"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
